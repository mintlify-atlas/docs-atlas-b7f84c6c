  "keyFeatures": [
    "RESTful API for package shipment management",
    "Semantic web integration with Apache Jena",
    "Natural language search using SPARQL queries",
    "OWL ontology-based data modeling",
    "Multi-branch shipment tracking",
    "Automated semantic graph synchronization"
  ],
  "publicApiSurface": [
    "POST /api/v1/envios - Create shipment",
    "GET /api/v1/envios/{id} - Get shipment by ID",
    "GET /api/v1/envios/seguimiento/{codigo} - Track shipment by code",
    "PUT /api/v1/envios/actualizar-estado - Update shipment status",
    "POST /api/v1/envios/asignar-placa - Assign vehicle to shipment",
    "PUT /api/v1/envios/{id}/disponible - Mark shipment as available",
    "POST /api/v1/envios/retirar - Retrieve package",
    "GET /api/v1/envios/estado/{estado} - Get shipments by status",
    "PUT /api/v1/envios/{id}/cancelar - Cancel shipment",
    "GET /api/v1/envios/mis-envios - Get user shipment history",
    "GET /api/v1/grafo/buscar - Natural language semantic search",
    "POST /api/v1/grafo/sincronizar-envio - Synchronize shipment to semantic graph",
    "POST /api/v1/grafo/sparql - Execute SPARQL query"
  ]
